# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
**/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Claude Code session data
.claude/

# Python cache
__pycache__/
*.pyc

# One-off fix/deploy scripts (root-level development artifacts)
/*.py

# Draft documents and interim reports (keep only in final submission)
*.pdf
docs/*.docx
docs/*.backup-*.docx
docs/*.pptx
data/*.pdf

# Parquet/data files (too large for public repo)
*.parquet

# Exploration summaries (dev notes, not deliverables)
docs/EXPLORATION-SUMMARY.md
docs/WEBSITE-EXPLORATION-SUMMARY.md
docs/reliability-core-migration.md
docs/website-analysis-*.md
docs/website-visual-summary.md

# Legacy pptx workspace artifacts
docs/pptx-workspace/

# Slide build tooling node_modules
docs/slides/workspace/node_modules/

# Temporary architecture diagrams
public/architecture-diagram-*.png
public/*.docx

# Python virtual environments
venv/
**/venv/

# Large data snapshots
data/core/market-snapshot.json

# Supabase local
supabase/

# CSS backups
*.css.backup
